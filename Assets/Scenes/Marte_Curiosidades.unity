PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 80509592771913235, guid: 93c4aca714e010c4c891f67a8ea37c64, type: 3}
      propertyPath: m_TargetTexture
      value: 
      objectReference: {fileID: 8400000, guid: 5ae838a73f4a1ee4980191866457ab0d, type: 2}
    - target: {fileID: 1621030916411396306, guid: 93c4aca714e010c4c891f67a8ea37c64, type: 3}
      propertyPath: m_text
      value: "Novos Ind\xEDcios de Vida: Em fevereiro de 2026, o rover Perseverance
        identificou associa\xE7\xF5es minerais e mat\xE9ria org\xE2nica na cratera
        Jezero que assemelham-se a ambientes moldados por atividade microbiana na
        Terra primitiva.\n\nAcelera\xE7\xE3o da Rota\xE7\xE3o: Dados recentes da
        miss\xE3o InSight revelaram que a rota\xE7\xE3o de Marte est\xE1 a acelerar
        cerca de 4 mil\xE9simos de segundo de arco por ano, o que encurta ligeiramente
        o dia marciano.\n\nSat\xE9lites: Possui duas pequenas luas, Fobos e Deimos.
        \n\nPores do Sol Azuis : Ao contr\xE1rio da Terra, onde o c\xE9u \xE9 azul
        e o p\xF4r do sol \xE9 vermelho, em Marte acontece o oposto. Devido \xE0
        poeira fina na atmosfera que dispersa a luz de forma diferente, o p\xF4r
        do sol em Marte \xE9 azulado.\n\nGravidade \"Ligeira\": A gravidade em Marte
        \xE9 apenas 38% da terrestre. Isto significa que, se estivesses l\xE1, conseguirias
        saltar tr\xEAs vezes mais alto e levantar objetos que aqui seriam pesad\xEDssimos
        para ti."
      objectReference: {fileID: 0}
    - target: {fileID: 4056698271683325552, guid: 93c4aca714e010c4c891f67a8ea37c64, type: 3}
      propertyPath: m_LocalPosition.x
