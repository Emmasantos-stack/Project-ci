--- !u!1001 &412818836
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 1621030916411396306, guid: 93c4aca714e010c4c891f67a8ea37c64, type: 3}
      propertyPath: m_text
      value: "Neptuno, o oitavo e mais distante planeta do Sistema Solar, \xE9 o
        \xFAltimo dos \"gigantes gelados\".\n\nVentos Supers\xF3nicos: Neptuno det\xE9m
        o recorde de ventos mais fortes do Sistema Solar, atingindo velocidades de
        2.100 km/h, ultrapassando a velocidade do som na Terra.\n\nComposi\xE7\xE3o
        e Cor: \xC9 composto por uma \"sopa\" densa de \xE1gua, metano e amon\xEDaco
        gelados sobre um n\xFAcleo rochoso. O metano absorve a luz vermelha, conferindo-lhe
        um tom azul profundo, mais intenso que o de Urano.\n\nDevido \xE0 sua enorme
        dist\xE2ncia (cerca de 4,5 mil milh\xF5es de quil\xF3metros do Sol), Neptuno
        \xE9 o \xFAnico planeta do Sistema Solar que nunca \xE9 vis\xEDvel a olho
        nu."
      objectReference: {fileID: 0}
    - target: {fileID: 3801520099650067127, guid: 93c4aca714e010c4c891f67a8ea37c64, type: 3}
      propertyPath: m_OnClick.m_PersistentCalls.m_Calls.Array.size
